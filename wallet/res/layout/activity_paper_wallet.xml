<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:id="@+id/paper_wallet_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/paper_wallet_warning"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="?android:attr/textColorSecondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:weightSum="2">

            <TextView
                android:id="@+id/paper_wallet_public_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/paper_wallet_public_label"
                android:textAppearance="?android:attr/textAppearanceMedium" />

            <TextView
                android:id="@+id/paper_wallet_key_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/paper_wallet_private_label"
                android:textAppearance="?android:attr/textAppearanceMedium" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:weightSum="2">

            <ImageView
                android:id="@+id/paper_wallet_qr_address"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_marginRight="8dp"
                android:layout_weight="1"
                android:background="#ffffff"
                android:padding="8dp" />

            <ImageView
                android:id="@+id/paper_wallet_qr_key"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_marginLeft="8dp"
                android:layout_weight="1"
                android:background="#ffffff"
                android:padding="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:weightSum="2">

            <TextView
                android:id="@+id/paper_wallet_address"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="8dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:gravity="center"
                android:maxLines="3"
                android:textIsSelectable="true"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/paper_wallet_key"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:gravity="center"
                android:maxLines="3"
                android:textIsSelectable="true"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 6 ICON BÁM THEO QR - KHUNG ĐÃ NỚI RỘNG -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="-4dp"
            android:layout_marginRight="-4dp"
            android:layout_marginTop="8dp"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="3dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/paper_wallet_copy_address"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/paper_wallet_copy"
                    android:src="@android:drawable/ic_menu_copy" />

                <ImageButton
                    android:id="@+id/paper_wallet_public_format"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/paper_wallet_public_format_bech32"
                    android:src="@android:drawable/ic_menu_sort_by_size" />

                <ImageButton
                    android:id="@+id/paper_wallet_toggle_address"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/paper_wallet_hide"
                    android:src="@android:drawable/ic_menu_view" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="3dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/paper_wallet_copy_privkey"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/paper_wallet_copy"
                    android:src="@android:drawable/ic_menu_copy" />

                <ImageButton
                    android:id="@+id/paper_wallet_privkey_format"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/paper_wallet_private_format_wif"
                    android:src="@android:drawable/ic_menu_sort_by_size" />

                <ImageButton
                    android:id="@+id/paper_wallet_toggle_key"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/paper_wallet_hide_key"
                    android:src="@android:drawable/ic_menu_close_clear_cancel" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="16dp"
            android:background="?android:attr/listDivider" />

        <CheckBox
            android:id="@+id/paper_wallet_encrypt_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_encrypt_bip38" />

        <CheckBox
            android:id="@+id/paper_wallet_show_pass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_show"
            android:visibility="gone" />

        <EditText
            android:id="@+id/paper_wallet_passphrase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:hint="@string/paper_wallet_passphrase"
            android:inputType="textPassword"
            android:visibility="gone" />

        <EditText
            android:id="@+id/paper_wallet_passphrase_confirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:hint="@string/paper_wallet_passphrase_confirm"
            android:inputType="textPassword"
            android:visibility="gone" />

        <TextView
            android:id="@+id/paper_wallet_bip38_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_bip38_hint"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="16dp"
            android:background="?android:attr/listDivider" />

        <!-- NÚT TẠO MỚI - GIỮ CHỮ + ICON CHO KHỎI LẠC LÕNG -->
        <Button
            android:id="@+id/paper_wallet_generate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:drawableLeft="@android:drawable/ic_menu_rotate"
            android:drawablePadding="8dp"
            android:gravity="center"
            android:text="@string/paper_wallet_generate_new"
            android:textAllCaps="false" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/paper_wallet_save"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/paper_wallet_save"
                android:src="@android:drawable/ic_menu_save" />

            <ImageButton
                android:id="@+id/paper_wallet_share"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/paper_wallet_share"
                android:src="@android:drawable/ic_menu_share" />

            <ImageButton
                android:id="@+id/paper_wallet_print"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/paper_wallet_print"
                android:src="@android:drawable/ic_menu_slideshow" />

            <ImageButton
                android:id="@+id/paper_wallet_export_txt"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/paper_wallet_export_txt"
                android:src="@android:drawable/ic_menu_edit" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
