<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/paper_wallet_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Warning text (giữ nguyên, cần string paper_wallet_warning) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="⚠️ Cảnh báo: giữ private key an toàn"   <!-- thay text cứng để khỏi phụ thuộc string -->
            android:textSize="12sp"
            android:textColor="#8A000000" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <TextView
                android:id="@+id/paper_wallet_public_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Địa chỉ công khai"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/paper_wallet_key_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Khóa riêng tư"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <ImageView
                android:id="@+id/paper_wallet_qr_address"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_marginRight="8dp"
                android:layout_weight="1"
                android:background="#ffffff"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_camera" />   <!-- thay tạm -->

            <ImageView
                android:id="@+id/paper_wallet_qr_key"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_marginLeft="8dp"
                android:layout_weight="1"
                android:background="#ffffff"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_camera" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <TextView
                android:id="@+id/paper_wallet_address"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="8dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:gravity="center"
                android:textIsSelectable="true"
                android:textSize="12sp"
                android:text="1A1zP1eP5QGefi2DMPTfTL5SLmv7DivfNa" />

            <TextView
                android:id="@+id/paper_wallet_key"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:gravity="center"
                android:textIsSelectable="true"
                android:textSize="12sp"
                android:text="L5BfD5YJ2M8E1g7..." />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="3dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/paper_wallet_copy_address"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_copy"      <!-- copy -->
                    android:tint="#FF757575" />

                <ImageButton
                    android:id="@+id/paper_wallet_public_format"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_rotate"    <!-- swap (xoay) -->
                    android:tint="#FF757575" />

                <ImageButton
                    android:id="@+id/paper_wallet_toggle_address"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_view"      <!-- eye (xem) -->
                    android:tint="#FF757575" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="3dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/paper_wallet_copy_privkey"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_copy"
                    android:tint="#FF757575" />

                <ImageButton
                    android:id="@+id/paper_wallet_privkey_format"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_rotate"
                    android:tint="#FF757575" />

                <ImageButton
                    android:id="@+id/paper_wallet_toggle_key"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"  <!-- eye off -->
                    android:tint="#FF757575" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp"
            android:background="#1F000000" />

        <CheckBox
            android:id="@+id/paper_wallet_encrypt_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mã hóa BIP38" />

        <CheckBox
            android:id="@+id/paper_wallet_show_pass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hiện mật khẩu"
            android:visibility="gone" />

        <EditText
            android:id="@+id/paper_wallet_passphrase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nhập mật khẩu"
            android:inputType="textPassword"
            android:enabled="false"
            android:visibility="gone" />

        <EditText
            android:id="@+id/paper_wallet_passphrase_confirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Xác nhận mật khẩu"
            android:inputType="textPassword"
            android:enabled="false"
            android:visibility="gone" />

        <TextView
            android:id="@+id/paper_wallet_bip38_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chú thích BIP38: nhập mật khẩu mạnh"
            android:textSize="12sp"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp"
            android:background="#1F000000" />

        <Button
            android:id="@+id/paper_wallet_generate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Tạo ví mới"
            android:textAllCaps="false"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/paper_wallet_save"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_save"
                android:tint="#FF757575" />

            <ImageButton
                android:id="@+id/paper_wallet_share"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_share"
                android:tint="#FF757575" />

            <ImageButton
                android:id="@+id/paper_wallet_print"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_print"
                android:tint="#FF757575" />

            <ImageButton
                android:id="@+id/paper_wallet_export_txt"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_edit"
                android:tint="#FF757575" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
