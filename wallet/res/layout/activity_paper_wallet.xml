<?xml version="1.0" encoding="utf-8"?>
<!-- Paper Wallet - bố trí 2 cột gọn -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:id="@+id/paper_wallet_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Warning -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_warning"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="?android:attr/textColorSecondary"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="16dp" />

        <!-- 2 cột Public | Private -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:baselineAligned="false">

            <!-- Cột Public -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="6dp"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/paper_wallet_public_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/paper_wallet_public_label"
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:textColor="?android:attr/textColorPrimary" />

                <ImageView
                    android:id="@+id/paper_wallet_qr_address"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_marginTop="10dp"
                    android:background="#ffffff"
                    android:padding="6dp" />

                <TextView
                    android:id="@+id/paper_wallet_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textIsSelectable="true"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="-0.01"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginTop="10dp"
                    android:paddingHorizontal="4dp" />

                <Button
                    android:id="@+id/paper_wallet_copy_address"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="4dp"
                    android:text="@string/paper_wallet_copy"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/paper_wallet_public_format"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:text="@string/paper_wallet_public_format_bech32"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/paper_wallet_toggle_address"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:text="@string/paper_wallet_hide"
                    android:textAllCaps="false" />
            </LinearLayout>

            <!-- Cột Private -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="6dp"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/paper_wallet_key_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/paper_wallet_private_label"
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:textColor="?android:attr/textColorPrimary" />

                <ImageView
                    android:id="@+id/paper_wallet_qr_key"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_marginTop="10dp"
                    android:background="#ffffff"
                    android:padding="6dp" />

                <TextView
                    android:id="@+id/paper_wallet_key"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textIsSelectable="true"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="-0.01"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginTop="10dp"
                    android:paddingHorizontal="4dp" />

                <Button
                    android:id="@+id/paper_wallet_copy_privkey"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="4dp"
                    android:text="@string/paper_wallet_copy"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/paper_wallet_privkey_format"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:text="@string/paper_wallet_private_format_wif"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/paper_wallet_toggle_key"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:text="@string/paper_wallet_hide_key"
                    android:textAllCaps="false" />
            </LinearLayout>
        </LinearLayout>

        <!-- ========== BIP38 ========== -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="12dp" />

        <CheckBox
            android:id="@+id/paper_wallet_encrypt_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_encrypt_bip38"
            android:textColor="?android:attr/textColorPrimary" />

        <CheckBox
            android:id="@+id/paper_wallet_show_pass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_show"
            android:textColor="?android:attr/textColorPrimary"
            android:visibility="gone" />

        <EditText
            android:id="@+id/paper_wallet_passphrase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/paper_wallet_passphrase"
            android:inputType="textPassword"
            android:enabled="false"
            android:visibility="gone" />

        <EditText
            android:id="@+id/paper_wallet_passphrase_confirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/paper_wallet_passphrase_confirm"
            android:inputType="textPassword"
            android:enabled="false"
            android:visibility="gone" />

        <TextView
            android:id="@+id/paper_wallet_bip38_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_bip38_hint"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="?android:attr/textColorSecondary"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp" />

        <!-- ========== Actions ========== -->
        <Button
            android:id="@+id/paper_wallet_generate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/paper_wallet_generate_new" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/paper_wallet_save"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="@string/paper_wallet_save"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/paper_wallet_share"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="@string/paper_wallet_share"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/paper_wallet_print"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="@string/paper_wallet_print"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/paper_wallet_export_txt"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="@string/paper_wallet_export_txt"
                android:textAllCaps="false" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
