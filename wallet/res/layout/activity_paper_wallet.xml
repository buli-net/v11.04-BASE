<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:id="@+id/paper_wallet_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_warning"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:textColor="?android:attr/textColorSecondary"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="16dp" />

        <!-- ===== Tiêu đề 2 cột bám QR ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:baselineAligned="false">

            <TextView
                android:id="@+id/paper_wallet_public_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/paper_wallet_public_label"
                android:textAppearance="?android:attr/textAppearanceMedium" />

            <TextView
                android:id="@+id/paper_wallet_key_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/paper_wallet_private_label"
                android:textAppearance="?android:attr/textAppearanceMedium" />
        </LinearLayout>

        <!-- ===== 2 QR bám theo 2 cột ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="10dp"
            android:baselineAligned="false">

            <ImageView
                android:id="@+id/paper_wallet_qr_address"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="#ffffff"
                android:padding="8dp" />

            <ImageView
                android:id="@+id/paper_wallet_qr_key"
                android:layout_width="0dp"
                android:layout_height="160dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="#ffffff"
                android:padding="8dp" />
        </LinearLayout>

        <!-- ===== Địa chỉ ví dưới QR - dạng như hình 2, cho phép xuống 3 dòng ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="10dp"
            android:baselineAligned="false">

            <TextView
                android:id="@+id/paper_wallet_address"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:textIsSelectable="true"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:letterSpacing="-0.01"
                android:lineSpacingExtra="2dp"
                android:maxLines="3"
                android:breakStrategy="balanced" />

            <TextView
                android:id="@+id/paper_wallet_key"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:textIsSelectable="true"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:letterSpacing="-0.01"
                android:lineSpacingExtra="2dp"
                android:maxLines="3"
                android:breakStrategy="balanced" />
        </LinearLayout>

        <!-- ===== 6 NÚT 1 HÀNG NHƯNG BÁM THEO QR ===== -->
        <!-- Mẹo: 1 hàng ngoài weightSum=2, trong có 2 cụm weight=1, mỗi cụm chứa 3 nút -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="6dp"
            android:baselineAligned="false">

            <!-- Cụm trái bám QR trái -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/paper_wallet_copy_address"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/paper_wallet_copy"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/paper_wallet_public_format"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/paper_wallet_public_format_bech32"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/paper_wallet_toggle_address"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/paper_wallet_hide"
                    android:textAllCaps="false"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Cụm phải bám QR phải -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/paper_wallet_copy_privkey"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/paper_wallet_copy"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/paper_wallet_privkey_format"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/paper_wallet_private_format_wif"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/paper_wallet_toggle_key"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/paper_wallet_hide_key"
                    android:textAllCaps="false"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- BIP38 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp" />

        <CheckBox
            android:id="@+id/paper_wallet_encrypt_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_encrypt_bip38" />

        <CheckBox
            android:id="@+id/paper_wallet_show_pass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_show"
            android:visibility="gone" />

        <EditText
            android:id="@+id/paper_wallet_passphrase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/paper_wallet_passphrase"
            android:inputType="textPassword"
            android:enabled="false"
            android:visibility="gone" />

        <EditText
            android:id="@+id/paper_wallet_passphrase_confirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/paper_wallet_passphrase_confirm"
            android:inputType="textPassword"
            android:enabled="false"
            android:visibility="gone" />

        <TextView
            android:id="@+id/paper_wallet_bip38_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/paper_wallet_bip38_hint"
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/paper_wallet_generate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/paper_wallet_generate_new" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/paper_wallet_save"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="@string/paper_wallet_save"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/paper_wallet_share"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="@string/paper_wallet_share"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/paper_wallet_print"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="@string/paper_wallet_print"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/paper_wallet_export_txt"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="@string/paper_wallet_export_txt"
                android:textAllCaps="false" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
