    <string name="wallet_old_sdk_dialog_title">Phiên bản Android đã cũ</string>
    <string name="wallet_old_sdk_dialog_message">Khả năng là một trong các bản phát hành tiếp theo của Ví Bitcoin sẽ không hỗ trợ thiết bị của bạn nữa. Trong một số trường hợp, có thể khó khăn để chi tiêu coin trên thiết bị này.\n\nTrừ khi bạn biết mình đang làm gì, bạn nên chuyển coin của mình ra ngoài sớm.</string>
